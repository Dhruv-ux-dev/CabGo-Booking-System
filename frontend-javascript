let currentUser = null
let selectedDriverId = null

const distanceMap = {
    "Patiala-Chandigarh":70,
    "Delhi-Noida":25,
    "Mohali-Chandigarh":15,
    "Delhi-Gurgaon":35,
    "Patiala-Delhi":250,
    "Jaipur-Delhi":280,
    "Delhi-Chandigarh":240,
    "Mohali-Delhi":260
}

const locations = [
    "Patiala",
    "Chandigarh",
    "Delhi",
    "Noida",
    "Mohali",
    "Gurgaon",
    "Jaipur"
]

function showRegister(){
    document.getElementById(
        'loginPage'
    ).style.display = 'none'

    document.getElementById(
        'registerPage'
    ).style.display = 'flex'
}

async function register(){
    try{
        const response = await fetch(
            'http://127.0.0.1:5000/register',
            {
                method:'POST',

                headers:{
                    'Content-Type':'application/json'
                },

                body:JSON.stringify({
                    phone:
                    document.getElementById(
                        'registerPhone'
                    ).value,

                    password:
                    document.getElementById(
                        'registerPassword'
                    ).value
                })
            }
        )

        const data = await response.json()

        alert(data.message)

        if(data.success){
            location.reload()
        }

    }catch(error){
        alert('Server Error')
    }
}

async function login(){
    try{
        const response = await fetch(
            'http://127.0.0.1:5000/login',
            {
                method:'POST',

                headers:{
                    'Content-Type':'application/json'
                },

                body:JSON.stringify({
                    phone:
                    document.getElementById(
                        'phone'
                    ).value,

                    password:
                    document.getElementById(
                        'password'
                    ).value
                })
            }
        )

        const data = await response.json()

        if(data.success){
            currentUser = data.user

            document.getElementById(
                'loginPage'
            ).style.display = 'none'

            document.getElementById(
                'dashboard'
            ).style.display = 'block'

            document.getElementById(
                'welcomeText'
            ).innerHTML = `Welcome`

            document.getElementById(
                'profilePhone'
            ).innerHTML =
            currentUser.phone

            showSection(
                'dashboardSection'
            )

            loadDrivers()
            loadStats()
            loadRides()
            loadPayments()

        }else{
            alert(data.message)
        }

    }catch(error){
        console.log(error)
        alert('Server Error')
    }
}

function showSection(sectionId){
    const sections = [
        'dashboardSection',
        'bookRideSection',
        'paymentSection',
        'rideHistorySection'
    ]

    sections.forEach((section)=>{
        document.getElementById(
            section
        ).style.display = 'none'
    })

    document.getElementById(
        sectionId
    ).style.display = 'block'
}

