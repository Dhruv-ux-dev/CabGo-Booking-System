                Driver:
                ${ride.driver_name}
                </p>

                <p class="muted mt-2">
                Amount:
                ₹${ride.fare}
                </p>

                <select
                id="payment-${ride.id}"
                class="input-box mt-5">

                    <option value="UPI">
                    UPI
                    </option>

                    <option value="Cash">
                    Cash
                    </option>

                </select>

                <select
                id="rating-${ride.id}"
                class="input-box mt-5">

                    <option value="5">
                    5 Stars
                    </option>

                    <option value="4">
                    4 Stars
                    </option>

