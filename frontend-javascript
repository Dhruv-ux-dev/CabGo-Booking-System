async function addDriver(){
    try{
        const response = await fetch(
            'http://127.0.0.1:5000/add-driver',
            {
                method:'POST',

                headers:{
                    'Content-Type':'application/json'
                },

                body:JSON.stringify({
                    name:
                    document.getElementById(
                        'driverName'
                    ).value,

                    cab_name:
                    document.getElementById(
                        'cabName'
                    ).value,

                    cab_number:
                    document.getElementById(
                        'cabNumber'
                    ).value
                })
            }
        )

        const data = await response.json()

        alert(data.message)

        if(data.success){
            loadAdminDrivers()
            loadDrivers()

            document.getElementById(
                'driverName'
            ).value = ''

            document.getElementById(
                'cabName'
            ).value = ''

            document.getElementById(
                'cabNumber'
            ).value = ''
        }

    }catch(error){
        alert('Error Adding Driver')
    }
}

async function deleteDriver(id){
    await fetch(
        `http://127.0.0.1:5000/delete-driver/${id}`,
        {
            method:'DELETE'
        }
    )

    loadAdminDrivers()
    loadDrivers()
}

function logout(){
    location.reload()
}
