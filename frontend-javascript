async function completeRide(
    rideId,
    driverId
){
    try{
        const rating =
        document.getElementById(
            `rating-${rideId}`
        ).value

        const paymentMethod =
        document.getElementById(
            `payment-${rideId}`
        ).value

        const response = await fetch(
            `http://127.0.0.1:5000/complete-ride/${rideId}`,
            {
                method:'PUT',

                headers:{
                    'Content-Type':'application/json'
                },

                body:JSON.stringify({
                    driver_id:Number(driverId),
                    rating:Number(rating),
                    payment_method:paymentMethod
                })
            }
        )

        const data = await response.json()

        alert(data.message)

        loadDrivers()
        loadPayments()
        loadRides()
        loadStats()

    }catch(error){
        alert('Payment Failed')
    }
}

async function cancelRide(
    rideId,
    driverId
){
    try{
        await fetch(
            `http://127.0.0.1:5000/cancel-ride/${rideId}`,
            {
                method:'PUT',

                headers:{
                    'Content-Type':'application/json'
                },

                body:JSON.stringify({
                    driver_id:
                    driverId
                })
            }
        )

        alert('Ride Cancelled')

        loadDrivers()
        loadPayments()
        loadRides()
        loadStats()

    }catch(error){
        alert('Cancel Failed')
    }
}

async function loadRides(){
    const response = await fetch(
        `http://127.0.0.1:5000/rides/${currentUser.id}`
    )

    const rides = await response.json()

    const container =
    document.getElementById(
        'rideHistory'
    )

    container.innerHTML = ''

    if(rides.length === 0){
        container.innerHTML = `
        <div class="ride-card">

            <h2>
            No Ride History
            </h2>

        </div>
        `

        return
    }

    rides.forEach((ride)=>{
        let statusClass = ''

        if(ride.status === 'ACTIVE'){
            statusClass = 'active'
        }

        if(ride.status === 'COMPLETED'){
            statusClass = 'completed'
        }

        if(ride.status === 'CANCELLED'){
            statusClass = 'cancelled'
        }

        container.innerHTML += `
        <div class="ride-card">

            <h2 class="text-2xl font-semibold">
            ${ride.pickup}
            →
            ${ride.destination}
            </h2>

            <p class="muted mt-2">
            Driver:
            ${ride.driver_name}
            </p>

            <p class="muted mt-2">
            Fare:
            ₹${ride.fare}
            </p>

            <div class="status-tag ${statusClass}">
            ${ride.status}
            </div>

        </div>
        `
    })
}

async function loadStats(){
    const response = await fetch(
        `http://127.0.0.1:5000/stats/${currentUser.id}`
    )

    const stats = await response.json()

    document.getElementById(
        'totalRides'
    ).innerHTML =
    stats.total_rides

    document.getElementById(
        'spent'
    ).innerHTML =
    `₹${stats.spent}`

    document.getElementById(
        'totalDrivers'
    ).innerHTML =
    stats.total_drivers
}

