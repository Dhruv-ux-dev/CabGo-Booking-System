function showSuggestions(type){
    const input =
    document.getElementById(type)

    const suggestionBox =
    document.getElementById(
        `${type}Suggestions`
    )

    const value =
    input.value.toLowerCase()

    suggestionBox.innerHTML = ''

    if(value === ''){
        return
    }

    const filtered = locations.filter(
        (location)=>
        location
        .toLowerCase()
        .includes(value)
    )

    filtered.forEach((location)=>{
        suggestionBox.innerHTML += `
        <div
        class="suggestion-item"
        onclick="selectLocation(
            '${type}',
            '${location}'
        )">

        ${location}

        </div>
        `
    })
}

function selectLocation(type,location){
    document.getElementById(
        type
    ).value = location

    document.getElementById(
        `${type}Suggestions`
    ).innerHTML = ''

    calculateRide()
}

async function loadDrivers(){
    try{
        const response = await fetch(
            'http://127.0.0.1:5000/drivers'
        )

        const drivers = await response.json()

        const container =
        document.getElementById(
            'driverList'
        )

        container.innerHTML = ''

        const availableDrivers = drivers.filter(
            (driver)=>
            driver.status === 'AVAILABLE'
        )

        if(availableDrivers.length === 0){
            container.innerHTML = `
            <div class="ride-card">

                <h2>
                No Drivers Available
                </h2>

            </div>
            `

            return
        }

        availableDrivers.forEach((driver)=>{
            container.innerHTML += `
            <div
            class="driver-option"
            onclick="selectDriver(
                ${driver.id},
                this
            )">

                <div class="driver-left">

                    <h3>
                    ${driver.name}
                    </h3>

                    <p>
                    ${driver.cab_name}
                    •
                    ${driver.cab_number}
                    </p>

                </div>

                <div class="driver-right">

                    <div class="driver-rating">
                    ⭐ ${driver.rating}
                    </div>

                    <p>
                    Available
                    </p>

                </div>

            </div>
            `
        })

    }catch(error){
        console.log(error)
    }
}

function selectDriver(id,element){
    selectedDriverId = id

    document
    .querySelectorAll('.driver-option')
    .forEach((driver)=>{
        driver.classList.remove(
            'active'
        )
    })

    element.classList.add(
        'active'
    )
}

function calculateRide(){
    const pickup =
    document.getElementById(
        'pickup'
    ).value.trim()

    const destination =
    document.getElementById(
        'destination'
    ).value.trim()

    if(
        pickup === '' ||
        destination === ''
    ){
        document.getElementById(
            'distanceText'
        ).innerHTML = '0 KM'

        document.getElementById(
            'fareText'
        ).innerHTML = '₹0'

        return
    }

    const key1 =
    `${pickup}-${destination}`

    const key2 =
    `${destination}-${pickup}`

    let distance =
        distanceMap[key1] ||
        distanceMap[key2]

    if(!distance){
        distance = 50
    }

    const fare = distance * 15

    document.getElementById(
        'distanceText'
    ).innerHTML =
    `${distance} KM`

    document.getElementById(
        'fareText'
    ).innerHTML =
    `₹${fare}`
}

async function bookRide(){
    try{
        const pickup =
        document.getElementById(
            'pickup'
        ).value

        const destination =
        document.getElementById(
            'destination'
        ).value

        if(
            pickup === '' ||
            destination === ''
        ){
            alert('Enter Locations')
            return
        }

        if(selectedDriverId === null){
            alert('Select Driver')
            return
        }

        const key1 =
        `${pickup}-${destination}`

        const key2 =
        `${destination}-${pickup}`

        let distance =
            distanceMap[key1] ||
            distanceMap[key2]

        if(!distance){
            distance = 50
        }

        const response = await fetch(
            'http://127.0.0.1:5000/book-ride',
            {
                method:'POST',

                headers:{
                    'Content-Type':'application/json'
                },

                body:JSON.stringify({
                    user_id:
                    currentUser.id,

                    driver_id:
                    selectedDriverId,

                    pickup:
                    pickup,

                    destination:
                    destination,

                    distance_km:
                    distance
                })
            }
        )

        const data = await response.json()

        alert(data.message)

        if(data.success){
            selectedDriverId = null

            document.getElementById(
                'pickup'
            ).value = ''

            document.getElementById(
                'destination'
            ).value = ''

            document.getElementById(
                'distanceText'
            ).innerHTML = '0 KM'

            document.getElementById(
                'fareText'
            ).innerHTML = '₹0'

            loadDrivers()
            loadPayments()
            loadRides()
            loadStats()
        }

    }catch(error){
        console.log(error)
        alert('Booking Failed')
    }
}

