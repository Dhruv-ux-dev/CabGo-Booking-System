DELIMITER //
CREATE PROCEDURE cb_login(
    IN p_phone VARCHAR(20),
    IN p_password VARCHAR(100)
)

BEGIN
    IF EXISTS (
        SELECT *
        FROM users
        WHERE phone = p_phone
        AND password = p_password
    )
    THEN
        SELECT 'LOGIN SUCCESSFUL' AS MESSAGE;
    ELSE
        SELECT 'INVALID DETAILS' AS MESSAGE;
    END IF;
END //
DELIMITER ;
DELIMITER //

CREATE PROCEDURE cb_book_ride(
    IN p_user_id INT,
    IN p_driver_id INT,
    IN p_pickup VARCHAR(255),
    IN p_destination VARCHAR(255),
    IN p_distance INT
)
BEGIN
    DECLARE v_fare INT;
    SET v_fare = p_distance * 15;
    INSERT INTO rides(
        user_id,
        driver_id,
        pickup,
        destination,
        distance_km,
        fare,
        status
    )
    VALUES(
        p_user_id,
        p_driver_id,
        p_pickup,
        p_destination,
        p_distance,
        v_fare,
        'ACTIVE'
    );
    INSERT INTO payments(
        ride_id,
        amount,
        payment_status,
        payment_method
    )
    VALUES(
        LAST_INSERT_ID(),
        v_fare,
        'PAID',
        'UPI'
    );
    SELECT 'RIDE BOOKED SUCCESSFULLY' AS MESSAGE;
END //
DELIMITER ;
DELIMITER //
CREATE PROCEDURE cb_complete_ride(
    IN p_ride_id INT
)
BEGIN
    UPDATE rides
    SET status = 'COMPLETED'
    WHERE id = p_ride_id;
    SELECT 'RIDE COMPLETED' AS MESSAGE;
END //
DELIMITER ;
DELIMITER //
CREATE TRIGGER trg_driver_busy
AFTER INSERT
ON rides
FOR EACH ROW
BEGIN
    UPDATE drivers
    SET status = 'BUSY'
    WHERE id = NEW.driver_id;
END //
DELIMITER ;
DELIMITER //
CREATE TRIGGER trg_driver_available
AFTER UPDATE
ON rides
FOR EACH ROW
BEGIN
    IF NEW.status = 'COMPLETED' THEN
        UPDATE drivers
        SET status = 'AVAILABLE'
        WHERE id = NEW.driver_id;
    END IF;
END //
DELIMITER ;


