@app.route('/book-ride', methods=['POST'])
def book_ride():
    try:
        db = create_connection()

        cursor = db.cursor(
            dictionary=True,
            buffered=True
        )

        data = request.json

        cursor.execute(
            """
            SELECT *
            FROM drivers
            WHERE id=%s
            """,
            (
                int(data['driver_id']),
            )
        )

        driver = cursor.fetchone()

        if not driver:
            safe_close(cursor, db)

            return jsonify({
                "success": False,
                "message": "Driver Not Found"
            })

        if driver['status'] != 'AVAILABLE':
            safe_close(cursor, db)

            return jsonify({
                "success": False,
                "message": "Driver Busy"
            })

        distance = int(data['distance_km'])
        fare = distance * 15

        cursor.execute(
            """
            INSERT INTO rides(
                user_id,
                driver_id,
                pickup,
                destination,
                distance_km,
                fare,
                status
            )
            VALUES(%s,%s,%s,%s,%s,%s,%s)
            """,
            (
                int(data['user_id']),
                int(data['driver_id']),
                data['pickup'],
                data['destination'],
                distance,
                fare,
                'ACTIVE'
            )
        )

        ride_id = cursor.lastrowid

        cursor.execute(
            """
            INSERT INTO payments(
                ride_id,
                amount,
                payment_status,
                payment_method,
                rating
            )
            VALUES(%s,%s,%s,%s,%s)
            """,
            (
                ride_id,
                fare,
                'PENDING',
                '',
                5
            )
        )

        cursor.execute(
            """
            UPDATE drivers
            SET status='BUSY'
            WHERE id=%s
            """,
            (
                int(data['driver_id']),
            )
        )

        safe_close(cursor, db)

        return jsonify({
            "success": True,
            "fare": fare,
            "message": "Ride Booked Successfully"
        })

    except Exception as e:
        print(e)
        traceback.print_exc()

        return jsonify({
            "success": False,
            "message": str(e)
        })

@app.route('/complete-ride/<int:id>', methods=['PUT'])
def complete_ride(id):
    try:
        db = create_connection()

        cursor = db.cursor(
            dictionary=True,
            buffered=True
        )

        data = request.json

        cursor.execute(
            """
            UPDATE rides
            SET status='COMPLETED'
            WHERE id=%s
            """,
            (id,)
        )

        cursor.execute(
            """
            UPDATE payments
            SET
            payment_status='PAID',
            payment_method=%s,
            rating=%s
            WHERE ride_id=%s
            """,
            (
                data['payment_method'],
                int(data['rating']),
                id
            )
        )

        cursor.execute(
            """
            UPDATE drivers
            SET status='AVAILABLE'
            WHERE id=%s
            """,
            (
                int(data['driver_id']),
            )
        )

        cursor.execute(
            """
            UPDATE drivers
            SET rating=(rating + %s)/2
            WHERE id=%s
            """,
            (
                int(data['rating']),
                int(data['driver_id'])
            )
        )

        safe_close(cursor, db)

        return jsonify({
            "success": True,
            "message": "Ride Completed"
        })

    except Exception as e:
        print(e)
        traceback.print_exc()

        return jsonify({
            "success": False,
            "message": str(e)
        })

