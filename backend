@app.route('/register', methods=['POST'])
def register():
    try:
        db = create_connection()

        cursor = db.cursor(
            dictionary=True,
            buffered=True
        )

        data = request.json

        phone = data.get('phone')
        password = data.get('password')

        if not phone or not password:
            safe_close(cursor, db)

            return jsonify({
                "success": False,
                "message": "Fill all fields"
            })

        cursor.execute(
            """
            INSERT INTO users(
                phone,
                password
            )
            VALUES(%s,%s)
            """,
            (
                phone,
                password
            )
        )

        safe_close(cursor, db)

        return jsonify({
            "success": True,
            "message": "Account Created"
        })

    except Exception as e:
        print(e)
        traceback.print_exc()

        return jsonify({
            "success": False,
            "message": str(e)
        })

