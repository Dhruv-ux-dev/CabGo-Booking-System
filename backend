@app.route('/stats/<int:id>')
def stats(id):
    try:
        db = create_connection()

        cursor = db.cursor(
            dictionary=True,
            buffered=True
        )

        cursor.execute(
            """
            SELECT COUNT(*) AS total
            FROM rides
            WHERE user_id=%s
            """,
            (id,)
        )

        total_rides = cursor.fetchone()['total']

        cursor.execute(
            """
            SELECT IFNULL(
                SUM(amount),
                0
            ) AS total
            FROM payments
            JOIN rides
            ON payments.ride_id = rides.id
            WHERE rides.user_id=%s
            """,
            (id,)
        )

        spent = cursor.fetchone()['total']

        cursor.execute(
            """
            SELECT COUNT(*) AS total
            FROM drivers
            """
        )

        total_drivers = cursor.fetchone()['total']

        safe_close(cursor, db)

        return jsonify({
            "total_rides": total_rides,
            "spent": spent,
            "total_drivers": total_drivers
        })

    except Exception as e:
        print(e)
        traceback.print_exc()

        return jsonify({
            "total_rides": 0,
            "spent": 0,
            "total_drivers": 0
        })

